#include <iostream>
#include <vector>
#include <deque>
#include <tuple>

using namespace std;

// दिशा (Directions):
// 0 → Right, 1 → Down, 2 → Left, 3 → Up
int dr[] = {0, 1, 0, -1};
int dc[] = {1, 0, -1, 0};

// State of BFS
struct State {
    int r, c;     // current position
    int dir;      // current direction
    int apple;    // next apple to eat
};

// dist[r][c][dir][apple] = minimum right turns to reach this state
int dist[61][61][4][152];

int solve() {
    int N;
    cin >> N;

    vector<vector<int>> grid(N, vector<int>(N));
    int max_apple = 0;

    //------------------------------------------------------------
    // Input + initialization
    //------------------------------------------------------------
    for (int i = 0; i < N; i++) {
        for (int j = 0; j < N; j++) {
            cin >> grid[i][j];

            // Track maximum apple number
            if (grid[i][j] > 0)
                max_apple = max(max_apple, grid[i][j]);

            // Initialize distances with large value (infinity)
            for (int d = 0; d < 4; d++) {
                for (int a = 0; a <= 151; a++) {
                    dist[i][j][d][a] = 1e9;
                }
            }
        }
    }

    //------------------------------------------------------------
    // 0-1 BFS (deque)
    //------------------------------------------------------------
    deque<State> dq;

    // Start at (0,0), facing RIGHT (dir = 0)
    // If starting cell has apple 1 → immediately eat it
    int first_apple = (grid[0][0] == 1) ? 2 : 1;

    dist[0][0][0][first_apple] = 0;
    dq.push_front({0, 0, 0, first_apple});

    //------------------------------------------------------------
    // BFS loop
    //------------------------------------------------------------
    while (!dq.empty()) {
        State curr = dq.front();
        dq.pop_front();

        int r = curr.r;
        int c = curr.c;
        int dir = curr.dir;
        int apple = curr.apple;

        int curr_cost = dist[r][c][dir][apple];

        //--------------------------------------------------------
        // Goal: all apples eaten
        //--------------------------------------------------------
        if (apple > max_apple) {
            return curr_cost;
        }

        //--------------------------------------------------------
        // 1. Move forward (cost = 0)
        //--------------------------------------------------------
        int nr = r + dr[dir];
        int nc = c + dc[dir];

        if (nr >= 0 && nr < N && nc >= 0 && nc < N && grid[nr][nc] != -1) {
            
            int next_apple = apple;

            // If next required apple found → eat it
            if (grid[nr][nc] == apple) {
                next_apple++;
            }

            // Relax state
            if (dist[nr][nc][dir][next_apple] > curr_cost) {
                dist[nr][nc][dir][next_apple] = curr_cost;

                // cost = 0 → push front
                dq.push_front({nr, nc, dir, next_apple});
            }
        }

        //--------------------------------------------------------
        // 2. Turn right (cost = 1)
        //--------------------------------------------------------
        int ndir = (dir + 1) % 4;

        if (dist[r][c][ndir][apple] > curr_cost + 1) {
            dist[r][c][ndir][apple] = curr_cost + 1;

            // cost = 1 → push back
            dq.push_back({r, c, ndir, apple});
        }
    }

    //------------------------------------------------------------
    // If not reachable
    //------------------------------------------------------------
    return -1;
}

//------------------------------------------------------------
// Main
//------------------------------------------------------------
int main() {
    int T;
    cin >> T;

    for (int t = 1; t <= T; t++) {
        cout << "#" << t << " " << solve() << endl;
    }

    return 0;
}
