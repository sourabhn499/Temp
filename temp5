import time
from google import genai

# Initialize the client with your valid API key
client = genai.Client(api_key="AIzaSyASFNmYkMBsbjXDB8uMECFCc_Zl-kBaViU")

# 1. Upload the file
# This supports PDF, images, audio, video, and text files.
print("Uploading file...")
myfile = client.files.upload(file=r"D:\tempo\document.pdf")

# 2. Wait for processing (especially important for Video/Large PDFs)
while myfile.state.name == "PROCESSING":
    print("Processing file...")
    time.sleep(2)
    myfile = client.files.get(name=myfile.name)

if myfile.state.name == "FAILED":
    raise ValueError(f"File processing failed: {myfile.state.name}")

# 3. Ask a question about the file
print("Asking question...")
response = client.models.generate_content(
    model="gemini-3-flash-preview",
    contents=[
        myfile,
        ""
    ]
)

print("\n--- Model Response ---")
print(response.text)





